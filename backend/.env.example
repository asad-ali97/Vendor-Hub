# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/vendor-management
# MongoDB Atlas (use this in production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/vendor-management?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
# In dev: http://localhost:5173
# In prod: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─── App URL (used in email links) ─────────────────────────────────────────────
APP_URL=http://localhost:5173

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Leave empty to disable emails. System works fine without it.
# Setup: Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=VendorHub <your.email@gmail.com>
